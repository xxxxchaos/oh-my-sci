{
  "name": "omo-sci",
  "version": "0.1.0",
  "description": "医学科研 AI 智能体团队 — 面向中国临床研究者的 OpenCode 插件，覆盖选题设计、文献检索、数据分析、论文撰写、审稿到投稿全流程",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "bin": {
    "omo-sci": "./bin/omo-sci.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "jsonc-parser": "^3.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "omo-sci",
    "医学研究",
    "临床研究",
    "AI agent",
    "open-code",
    "科学研究",
    "论文写作",
    "文献检索",
    "统计分析",
    "系统评价"
  ],
  "files": [
    "src/",
    "bin/",
    ".opencode/",
    "docs/",
    "CHANGELOG.md",
    "README.md"
  ]
}
